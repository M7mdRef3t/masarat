{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "lib",
    "baseUrl": ".",
    "paths": {
      "@alrehla/masarat": ["./lib/index.ts"]
    }
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
